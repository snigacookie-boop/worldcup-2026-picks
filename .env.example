# Copy to .env.local for `npm run dev` and paste these into Netlify env vars for production.
# Anything prefixed with VITE_ is bundled into the client. Keep service-role + API keys server-only.

# ---- Client (Supabase) ----
# From Supabase: Project Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: set to 1 to render the demo UI without signing in. Useful for previewing styles.
# VITE_DEMO=1

# ---- Server (Netlify functions only) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# football-data.org free API key (register at https://www.football-data.org/client/register).
FOOTBALL_DATA_API_KEY=your-football-data-org-key
# WC 2026 competition code. Update if football-data uses a different code at launch.
FOOTBALL_DATA_COMPETITION=WC
